extends Resource
class_name GemData

@export var gem_id: String = ""

enum GemCategory {
	MADNESS, NIGHTMARE, VOID, FLESH, REALITY, SACRIFICE, SCANDALIST, 
	UNDERWORLD, TWILIGHT_FOREST, BLOOD_LORD, MAGIC_DEFENSE, SANITY_GEM, 
	HOLY_GEM, MILITARY_LEADER, TYRANNY, MAGNIFICENCE, WARDEN, BALLAST
}
enum StatType {
	HEALTH, HEALTH_STEAL, LUCK, MANA, KRIT_CHANSE, ALL_STATS, SPEED, 
	STAMINA, SANITY, DEFENSE, SPELL_DAMAGE, ARROW_DAMAGE, SWORD_DAMAGE, 
	EFFICIENCY, CRITICAL_CHANSE_DAMAGE, STAMINA_REGEN, MANA_REGEN, HP_REGEN, ATTACK_SPEED, 
	RECHARGE, SPELL_COOLDOWN
}

func _init():
	if gem_id.is_empty():
		gem_id = _generate_gem_id()

func _generate_gem_id() -> String:
	return "gem_%s_%s_%s" % [gem_category, level, Time.get_ticks_msec()]


@export var gem_name: String = ""
@export var gem_category: GemCategory
@export var level: int = 1
@export var stat_boosts: Dictionary = {}
@export var texture: Texture2D
@export_multiline var description: String = ""

