		StatType.STAMINA: return "Стамина"
		StatType.SANITY: return "Рассудок"
		StatType.DEFENSE: return "Защита"
		StatType.SPELL_DAMAGE: return "Урон заклинаний"
		StatType.ARROW_DAMAGE: return "Урон стрел"
		StatType.SWORD_DAMAGE: return "Урон меча"
